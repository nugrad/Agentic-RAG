# Use slim python image — full image is 1GB+ unnecessary
FROM python:3.11-slim

# Set working directory inside container
WORKDIR /app

# Copy requirements first — Docker layer caching
# If requirements.txt hasn't changed, this layer is cached
# and pip install doesn't rerun on every build
COPY requirements.txt .

# Install dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy rest of the project
COPY . .

# Create data directories in case they don't exist
RUN mkdir -p data/papers data/chroma_db

# Expose the port FastAPI runs on
EXPOSE 8000

# Start the server
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]